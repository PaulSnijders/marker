<Window x:Class="Marker.App.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Marker"
        SizeToContent="Height" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Background="{DynamicResource AppBackground}"
        Foreground="{DynamicResource AppForeground}">
    <StackPanel Margin="20">
        <TextBlock x:Name="MessageText"
                   TextWrapping="Wrap" LineHeight="20"
                   Foreground="{DynamicResource AppForeground}" />
        <StackPanel x:Name="ButtonRow"
                    Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <Button x:Name="OkButton" Content="OK" MinWidth="90" IsDefault="True"
                    Click="OnOk" Margin="0,0,8,0" Padding="6,4" />
            <Button x:Name="CancelButton" Content="Cancel" MinWidth="90" IsCancel="True"
                    Padding="6,4" />
        </StackPanel>
    </StackPanel>
</Window>
