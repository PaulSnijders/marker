<Window x:Class="Marker.App.Views.ReplaceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Find and Replace"
        SizeToContent="Height" Width="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Background="{DynamicResource AppBackground}"
        Foreground="{DynamicResource AppForeground}">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Find:" Grid.Row="0" Grid.Column="0"
                   VerticalAlignment="Center" Margin="0,0,8,8" />
        <TextBox x:Name="FindBox" Grid.Row="0" Grid.Column="1"
                 Padding="3" Margin="0,0,0,8" />

        <TextBlock Text="Replace:" Grid.Row="1" Grid.Column="0"
                   VerticalAlignment="Center" Margin="0,0,8,8" />
        <TextBox x:Name="ReplaceBox" Grid.Row="1" Grid.Column="1"
                 Padding="3" Margin="0,0,0,8" />

        <CheckBox x:Name="MatchCaseBox" Grid.Row="2" Grid.Column="1"
                  Content="Match case" Margin="0,0,0,8" />

        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Find Next" Width="90" Margin="0,0,8,0"
                    Padding="4" Click="OnFindNext" IsDefault="True" />
            <Button Content="Replace" Width="80" Margin="0,0,8,0"
                    Padding="4" Click="OnReplace" />
            <Button Content="Replace All" Width="90" Margin="0,0,8,0"
                    Padding="4" Click="OnReplaceAll" />
            <Button Content="Close" Width="70" Padding="4" Click="OnClose" />
        </StackPanel>
    </Grid>
</Window>
