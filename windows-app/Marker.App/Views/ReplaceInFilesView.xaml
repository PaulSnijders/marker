<UserControl x:Class="Marker.App.Views.ReplaceInFilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Marker.App.Views"
             xmlns:vm="clr-namespace:Marker.App.ViewModels"
             Background="{DynamicResource PanelBackground}"
             Foreground="{DynamicResource AppForeground}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Preview row: two stacked lines via LineBreak inlines in a single
             TextBlock (cheap to virtualise inside the TreeView). -->
        <DataTemplate x:Key="PreviewTemplate" DataType="{x:Type vm:ReplacePreviewItem}">
            <StackPanel Orientation="Horizontal" Margin="0,1">
                <TextBlock Text="{Binding LineNumber, StringFormat={}{0,5}:}"
                           Foreground="{DynamicResource MutedForeground}"
                           FontFamily="Cascadia Code, Consolas"
                           FontSize="11"
                           VerticalAlignment="Top"
                           Margin="0,1,8,0" />
                <TextBlock views:ReplacePreviewHighlight.Item="{Binding}"
                           Foreground="{DynamicResource AppForeground}"
                           VerticalAlignment="Top"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>

        <HierarchicalDataTemplate DataType="{x:Type vm:FileReplacesViewModel}"
                                  ItemsSource="{Binding Items}"
                                  ItemTemplate="{StaticResource PreviewTemplate}">
            <StackPanel Orientation="Horizontal" Margin="0,1">
                <TextBlock Text="{Binding FileName}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AppForeground}"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding RelativePath}"
                           Foreground="{DynamicResource MutedForeground}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </HierarchicalDataTemplate>

        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="Padding" Value="2,2" />
            <EventSetter Event="MouseLeftButtonUp" Handler="OnTreeItemClick" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Search box -->
        <TextBox Grid.Row="0" x:Name="QueryBox"
                 Margin="5,5,5,4" Padding="5,3"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 KeyDown="OnQueryKeyDown"
                 ToolTip="Find pattern" />

        <!-- Replace box. Ctrl+Enter commits Replace All. -->
        <TextBox Grid.Row="1" x:Name="ReplaceBox"
                 Margin="5,0,5,4" Padding="5,3"
                 Text="{Binding ReplacementText, UpdateSourceTrigger=PropertyChanged}"
                 KeyDown="OnReplaceBoxKeyDown"
                 ToolTip="Replacement — Ctrl+Enter to Replace All  ·  in regex mode, $1 / $2 / ${name} resolve capture groups" />

        <!-- Options + Replace All -->
        <DockPanel Grid.Row="2" Margin="5,0,5,4" LastChildFill="False">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <ToggleButton Style="{StaticResource SearchToggleButton}"
                              Content="Aa" ToolTip="Match case"
                              Margin="0,0,3,0"
                              IsChecked="{Binding MatchCase, Mode=TwoWay}" />
                <ToggleButton Style="{StaticResource SearchToggleButton}"
                              Content="W" ToolTip="Match whole words"
                              Margin="0,0,3,0"
                              IsChecked="{Binding WholeWord, Mode=TwoWay}" />
                <ToggleButton Style="{StaticResource SearchToggleButton}"
                              Content=".*" ToolTip="Regular expression"
                              Margin="0,0,3,0"
                              IsChecked="{Binding UseRegex, Mode=TwoWay}" />
            </StackPanel>
            <Button DockPanel.Dock="Right" Content="Replace All"
                    Padding="8,3" Click="OnReplaceAll"
                    IsEnabled="{Binding CanReplaceAll}"
                    ToolTip="Apply the preview to every file on disk" />
        </DockPanel>

        <TextBlock Grid.Row="3" Margin="7,0,5,5"
                   Text="{Binding StatusText}"
                   Foreground="{DynamicResource MutedForeground}"
                   FontSize="11"
                   TextTrimming="CharacterEllipsis" />

        <TreeView Grid.Row="4" x:Name="ResultsTree"
                  ItemsSource="{Binding Files}"
                  Background="Transparent" BorderThickness="0"
                  Foreground="{DynamicResource AppForeground}"
                  KeyDown="OnResultsKeyDown"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling" />
    </Grid>
</UserControl>
