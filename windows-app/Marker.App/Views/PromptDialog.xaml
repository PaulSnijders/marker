<Window x:Class="Marker.App.Views.PromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Marker"
        SizeToContent="Height" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Background="{DynamicResource AppBackground}"
        Foreground="{DynamicResource AppForeground}">
    <StackPanel Margin="16">
        <TextBlock x:Name="MessageText" Margin="0,0,0,8" TextWrapping="Wrap" />
        <TextBox x:Name="InputBox" Padding="4" FontSize="13" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="OkButton" Content="OK" Width="80" IsDefault="True"
                    Click="OnOk" Margin="0,0,8,0" Padding="4" />
            <Button Content="Cancel" Width="80" IsCancel="True" Padding="4" />
        </StackPanel>
    </StackPanel>
</Window>
