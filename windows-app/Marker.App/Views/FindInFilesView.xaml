<UserControl x:Class="Marker.App.Views.FindInFilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Marker.App.Views"
             xmlns:vm="clr-namespace:Marker.App.ViewModels"
             xmlns:search="clr-namespace:Marker.Core.Search;assembly=Marker.Core"
             Background="{DynamicResource PanelBackground}"
             Foreground="{DynamicResource AppForeground}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Match row: line number muted, line text with the hit highlighted. -->
        <DataTemplate x:Key="MatchTemplate" DataType="{x:Type search:SearchMatch}">
            <StackPanel Orientation="Horizontal" Margin="0,1">
                <TextBlock Text="{Binding LineNumber, StringFormat={}{0,5}:}"
                           Foreground="{DynamicResource MutedForeground}"
                           FontFamily="Cascadia Code, Consolas"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBlock views:MatchHighlight.Match="{Binding}"
                           Foreground="{DynamicResource AppForeground}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>

        <!-- File group: filename in bold, relative path muted next to it. -->
        <HierarchicalDataTemplate DataType="{x:Type vm:FileMatchesViewModel}"
                                  ItemsSource="{Binding Matches}"
                                  ItemTemplate="{StaticResource MatchTemplate}">
            <StackPanel Orientation="Horizontal" Margin="0,1">
                <TextBlock Text="{Binding FileName}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AppForeground}"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding RelativePath}"
                           Foreground="{DynamicResource MutedForeground}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- Tree item: expand by default for file groups, jump on single click.
             Chevron clicks expand/collapse via the built-in ToggleButton, which
             marks the event handled — so OnTreeItemClick only sees row clicks. -->
        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="Padding" Value="2,2" />
            <EventSetter Event="MouseLeftButtonUp" Handler="OnTreeItemClick" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Search box -->
        <TextBox Grid.Row="0" x:Name="QueryBox"
                 Margin="5,5,5,4" Padding="5,3"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 KeyDown="OnQueryKeyDown"
                 ToolTip="Find in all files in the workspace (Ctrl+Shift+F)" />

        <!-- Option toggles + result count, single row -->
        <DockPanel Grid.Row="1" Margin="5,0,5,4" LastChildFill="True">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <ToggleButton Style="{StaticResource SearchToggleButton}"
                              Content="Aa" ToolTip="Match case"
                              Margin="0,0,3,0"
                              IsChecked="{Binding MatchCase, Mode=TwoWay}" />
                <ToggleButton Style="{StaticResource SearchToggleButton}"
                              Content="W" ToolTip="Match whole words"
                              Margin="0,0,3,0"
                              IsChecked="{Binding WholeWord, Mode=TwoWay}" />
                <ToggleButton Style="{StaticResource SearchToggleButton}"
                              Content=".*" ToolTip="Regular expression"
                              Margin="0,0,3,0"
                              IsChecked="{Binding UseRegex, Mode=TwoWay}" />
            </StackPanel>
        </DockPanel>

        <!-- Status line -->
        <TextBlock Grid.Row="2" Margin="7,0,5,5"
                   Text="{Binding StatusText}"
                   Foreground="{DynamicResource MutedForeground}"
                   FontSize="11"
                   TextTrimming="CharacterEllipsis" />

        <!-- Results tree -->
        <TreeView Grid.Row="3" x:Name="ResultsTree"
                  ItemsSource="{Binding Files}"
                  Background="Transparent" BorderThickness="0"
                  Foreground="{DynamicResource AppForeground}"
                  KeyDown="OnResultsKeyDown"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling" />
    </Grid>
</UserControl>
