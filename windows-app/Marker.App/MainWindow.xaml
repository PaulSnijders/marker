<Window x:Class="Marker.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Marker.App"
        xmlns:vm="clr-namespace:Marker.App.ViewModels"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Marker"
        Icon="Assets/icon-marker.png"
        Height="720" Width="1100"
        Background="{DynamicResource AppBackground}"
        Foreground="{DynamicResource AppForeground}"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        AllowDrop="True"
        PreviewDragOver="OnWindowDragOver"
        PreviewDrop="OnWindowDrop">

    <Window.Resources>
        <local:StringToBrushConverter x:Key="StrToBrush" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- File tree node template -->
        <HierarchicalDataTemplate DataType="{x:Type vm:FileSystemNodeViewModel}"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="0,1">
                <TextBlock Text="{Binding Glyph}"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="13"
                           Foreground="{Binding GlyphColor, Converter={StaticResource StrToBrush}}"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0" />
                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                           Foreground="{DynamicResource AppForeground}" />
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- Tree node context menu -->
        <ContextMenu x:Key="NodeMenu">
            <MenuItem Header="New File…"  Click="OnNewFile" />
            <MenuItem Header="New Folder…" Click="OnNewFolder" />
            <Separator />
            <MenuItem Header="Rename…" Click="OnRename" />
            <MenuItem Header="Delete" Click="OnDelete" />
            <Separator />
            <MenuItem Header="Reveal in Explorer" Click="OnRevealInExplorer" />
            <MenuItem Header="Remove Folder from Workspace" Click="OnRemoveFolder" />
        </ContextMenu>

        <!-- Tree item: bind expansion/selection, attach context menu -->
        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
            <Setter Property="ContextMenu" Value="{StaticResource NodeMenu}" />
            <Setter Property="Padding" Value="2,0" />
            <Setter Property="AllowDrop" Value="True" />
            <EventSetter Event="PreviewMouseRightButtonDown" Handler="OnTreeItemRightClick" />
            <EventSetter Event="MouseLeftButtonUp" Handler="OnTreeItemClick" />
        </Style>

        <!-- Editor tab context menu -->
        <ContextMenu x:Key="TabContextMenu">
            <MenuItem Header="Close" Click="OnTabCtxClose" />
            <MenuItem Header="Close Other Tabs" Click="OnTabCtxCloseOthers" />
            <MenuItem Header="Close All Tabs" Click="OnTabCtxCloseAll" />
            <Separator />
            <MenuItem Header="Reveal in Explorer" Click="OnTabCtxReveal" />
            <MenuItem Header="Copy Full Path" Click="OnTabCtxCopyPath" />
        </ContextMenu>

        <!-- Editor tab item -->
        <Style x:Key="TabItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="ContextMenu" Value="{StaticResource TabContextMenu}" />
            <EventSetter Event="PreviewMouseDown" Handler="OnTabPreviewMouseDown" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Background="{DynamicResource TabBarBackground}"
                                BorderBrush="{DynamicResource BorderBrushColor}"
                                BorderThickness="0,0,1,0">
                            <StackPanel Orientation="Horizontal" Margin="10,5">
                                <Ellipse Width="7" Height="7" Margin="0,0,5,0"
                                         VerticalAlignment="Center"
                                         Fill="{DynamicResource AccentBrush}"
                                         Visibility="{Binding IsDirty, Converter={StaticResource BoolToVis}}" />
                                <TextBlock x:Name="TitleText" Text="{Binding Title}"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource AppForeground}" />
                                <Button Content=""
                                        Style="{StaticResource FlatIconButton}"
                                        FontFamily="Segoe MDL2 Assets" FontSize="9"
                                        Margin="8,0,0,0" Padding="3"
                                        Click="OnCloseTabButton"
                                        ToolTip="Close (middle-click)" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background"
                                        Value="{DynamicResource TabActiveBackground}" />
                            </Trigger>
                            <!-- Sneak-peek (preview) tabs show their name in italic. -->
                            <DataTrigger Binding="{Binding IsPreview}" Value="True">
                                <Setter TargetName="TitleText" Property="FontStyle"
                                        Value="Italic" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource StatusBarForeground}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="8,0" />
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- ===== Menu ===== -->
        <Menu DockPanel.Dock="Top"
              Background="{DynamicResource PanelBackground}"
              Foreground="{DynamicResource AppForeground}">
            <MenuItem Header="_File">
                <MenuItem Header="Quick Open File…" InputGestureText="Ctrl+P"
                          Click="OnQuickOpenFile" />
                <Separator />
                <MenuItem Header="New File…" InputGestureText="Ctrl+N" Click="OnNewFile" />
                <MenuItem Header="New Folder…" Click="OnNewFolder" />
                <MenuItem Header="Add Folder to Workspace…" Click="OnAddWorkspace" />
                <Separator />
                <MenuItem Header="Save" InputGestureText="Ctrl+S" Click="OnSave" />
                <MenuItem Header="Save All" InputGestureText="Ctrl+Shift+S" Click="OnSaveAll" />
                <Separator />
                <MenuItem x:Name="RecentMenu" Header="Recent Files" />
                <Separator />
                <MenuItem Header="Close Tab" InputGestureText="Ctrl+W" Click="OnCloseTab" />
                <MenuItem Header="Exit" Click="OnExit" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="Undo" InputGestureText="Ctrl+Z" Click="OnUndo" />
                <MenuItem Header="Redo" InputGestureText="Ctrl+Y" Click="OnRedo" />
                <Separator />
                <MenuItem Header="Find…" InputGestureText="Ctrl+F" Click="OnFind" />
                <MenuItem Header="Replace…" InputGestureText="Ctrl+H" Click="OnReplace" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem x:Name="ModeSourceItem" Header="Source Mode" IsCheckable="True"
                          Click="OnModeSource" />
                <MenuItem x:Name="ModeRichItem" Header="Rich Mode (WYSIWYG)" IsCheckable="True"
                          Click="OnModeRich" />
                <MenuItem x:Name="ModeReadItem" Header="Read Mode" IsCheckable="True"
                          Click="OnModeRead" />
                <MenuItem Header="Cycle Mode" InputGestureText="Ctrl+M" Click="OnCycleMode" />
                <Separator />
                <MenuItem x:Name="WordWrapItem" Header="Word Wrap (Source Mode)"
                          IsCheckable="True" Click="OnToggleWordWrap" />
                <MenuItem Header="Editor Font Size" x:Name="FontSizeMenu">
                    <MenuItem Header="Small — 12 pt" Tag="12" IsCheckable="True" Click="OnSetFontSize" />
                    <MenuItem Header="Normal — 13 pt" Tag="13" IsCheckable="True" Click="OnSetFontSize" />
                    <MenuItem Header="Comfortable — 15 pt" Tag="15" IsCheckable="True" Click="OnSetFontSize" />
                    <MenuItem Header="Large — 18 pt" Tag="18" IsCheckable="True" Click="OnSetFontSize" />
                    <MenuItem Header="Extra Large — 22 pt" Tag="22" IsCheckable="True" Click="OnSetFontSize" />
                </MenuItem>
                <Separator />
                <MenuItem Header="Toggle Light/Dark Theme" Click="OnToggleTheme" />
            </MenuItem>
            <MenuItem Header="_Workspace">
                <MenuItem Header="Switch Workspace…" InputGestureText="Ctrl+Shift+W"
                          Click="OnSwitchWorkspace" />
                <MenuItem Header="Focus File Tree" InputGestureText="Ctrl+T"
                          Click="OnFocusTree" />
                <Separator />
                <MenuItem Header="New Workspace…" Click="OnNewWorkspace" />
                <MenuItem Header="Rename Workspace…" Click="OnRenameWorkspace" />
                <MenuItem Header="Delete Workspace…" Click="OnDeleteWorkspace" />
                <Separator />
                <MenuItem Header="Add Folder…" Click="OnAddWorkspace" />
                <MenuItem Header="Remove Selected Folder" Click="OnRemoveFolder" />
                <MenuItem Header="Refresh Tree" Click="OnRefreshTree" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="Keyboard Shortcuts" InputGestureText="Esc"
                          Click="OnShowCheatsheet" />
                <MenuItem Header="Marker Help" Click="OnHelp" />
            </MenuItem>
        </Menu>

        <!-- ===== Status bar ===== -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource StatusBarBackground}"
                Height="24">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Style="{StaticResource StatusText}"
                           Text="{Binding SelectedTab.FilePath}"
                           TextTrimming="CharacterEllipsis" MaxWidth="600" />
                <TextBlock DockPanel.Dock="Right" Style="{StaticResource StatusText}">
                    <Run Text="Ln " /><Run Text="{Binding SelectedTab.CaretLine, Mode=OneWay}" />
                    <Run Text=", Col " /><Run Text="{Binding SelectedTab.CaretColumn, Mode=OneWay}" />
                </TextBlock>
                <TextBlock DockPanel.Dock="Right" Style="{StaticResource StatusText}"
                           Text="{Binding SelectedTab.LineEndingLabel}" />
                <TextBlock DockPanel.Dock="Right" Style="{StaticResource StatusText}"
                           Text="{Binding SelectedTab.EncodingLabel}" />
                <TextBlock DockPanel.Dock="Right" Style="{StaticResource StatusText}"
                           Text="{Binding SelectedTab.TypeName}" />
            </DockPanel>
        </Border>

        <!-- ===== Main split ===== -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="TreeColumn" Width="260" MinWidth="120" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" MinWidth="260" />
            </Grid.ColumnDefinitions>

            <!-- File tree -->
            <Border Grid.Column="0" Background="{DynamicResource PanelBackground}"
                    BorderBrush="{DynamicResource BorderBrushColor}" BorderThickness="0,0,1,0"
                    AllowDrop="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Workspace switcher: pick a workspace, or create one.
                         Rename / Delete live in the Workspace menu. -->
                    <DockPanel Grid.Row="0" Margin="5"
                               LastChildFill="True">
                        <Button DockPanel.Dock="Right" Style="{StaticResource FlatIconButton}"
                                Click="OnNewWorkspace"
                                Content="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                Width="26" Height="24" Margin="3,0,0,0"
                                ToolTip="New workspace" />
                        <ComboBox x:Name="WorkspaceSelector" Height="24"
                                  VerticalContentAlignment="Center"
                                  ItemsSource="{Binding AllWorkspaces}"
                                  SelectedItem="{Binding ActiveWorkspace, Mode=TwoWay}"
                                  SelectionChanged="OnWorkspaceSelected"
                                  ToolTip="Switch workspace" />
                    </DockPanel>

                    <TreeView Grid.Row="1" x:Name="TreeViewMain"
                              ItemsSource="{Binding RootFolders}"
                              Background="Transparent" BorderThickness="0"
                              Foreground="{DynamicResource AppForeground}"
                              AllowDrop="True"
                              SelectedItemChanged="OnTreeSelectionChanged"
                              PreviewKeyDown="OnTreeKeyDown"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling" />
                    <TextBlock Grid.Row="1"
                               Text="No folders in this workspace.&#x0a;Drag a folder here, or use Workspace ▸ Add Folder…"
                               Foreground="{DynamicResource MutedForeground}"
                               TextAlignment="Center" Margin="12"
                               VerticalAlignment="Top" HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               x:Name="TreeEmptyHint" />
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{DynamicResource BorderBrushColor}" />

            <!-- Editor area -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" MinHeight="32"
                           Background="{DynamicResource TabBarBackground}">
                    <!-- Always-present scratchpad button, kept to the right of
                         every tab. Out of the way until you need it. -->
                    <Button DockPanel.Dock="Right" x:Name="ScratchpadButton"
                            Style="{StaticResource FlatIconButton}"
                            Click="OnOpenScratchpad"
                            Content="&#xE70B;"
                            FontFamily="Segoe MDL2 Assets" FontSize="15"
                            Width="38"
                            BorderBrush="{DynamicResource BorderBrushColor}"
                            BorderThickness="1,0,0,1"
                            ToolTip="Scratchpad — markdown notes for this workspace (always here)" />
                    <ListBox x:Name="TabStrip"
                             ItemsSource="{Binding Tabs}"
                             SelectedItem="{Binding SelectedTab, Mode=TwoWay}"
                             ItemContainerStyle="{StaticResource TabItemStyle}"
                             Background="{DynamicResource TabBarBackground}"
                             BorderThickness="0,0,0,1"
                             BorderBrush="{DynamicResource BorderBrushColor}"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    </ListBox>
                </DockPanel>

                <Grid Grid.Row="1">
                    <avalonedit:TextEditor x:Name="Editor"
                                           ShowLineNumbers="True"
                                           Background="{DynamicResource EditorBackground}"
                                           Foreground="{DynamicResource AppForeground}"
                                           Padding="6,4" />
                    <wv2:WebView2 x:Name="Web" Visibility="Collapsed" />
                    <Border x:Name="BinaryNotice" Visibility="Collapsed"
                            Background="{DynamicResource EditorBackground}">
                        <TextBlock Text="Binary file — cannot edit."
                                   Foreground="{DynamicResource MutedForeground}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="14" />
                    </Border>
                    <Border x:Name="EmptyState"
                            Background="{DynamicResource EditorBackground}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Marker" FontSize="28" FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource MutedForeground}" />
                            <TextBlock Text="Open a file from the tree to start editing."
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource MutedForeground}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- Keyboard cheat sheet: toggled with Esc when nothing else
                 needs the key (no search bar, dialog, etc. to dismiss). -->
            <Popup x:Name="CheatsheetPopup" StaysOpen="False" Placement="Center"
                   AllowsTransparency="True">
                <Border Background="{DynamicResource PanelBackground}"
                        BorderBrush="{DynamicResource BorderBrushColor}"
                        BorderThickness="1" CornerRadius="6" Padding="22">
                    <StackPanel>
                        <TextBlock Text="Keyboard shortcuts" FontSize="16"
                                   FontWeight="SemiBold" Margin="0,0,0,14"
                                   Foreground="{DynamicResource AppForeground}" />
                        <ItemsControl x:Name="CheatsheetItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,3">
                                        <Border DockPanel.Dock="Left" Width="130"
                                                Background="{DynamicResource HoverBackground}"
                                                BorderBrush="{DynamicResource BorderBrushColor}"
                                                BorderThickness="1" CornerRadius="3"
                                                Padding="7,2" Margin="0,0,14,0">
                                            <TextBlock Text="{Binding Key}"
                                                       FontFamily="Consolas" FontSize="12"
                                                       Foreground="{DynamicResource AppForeground}" />
                                        </Border>
                                        <TextBlock Text="{Binding Action}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource AppForeground}" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Press Esc to close" FontSize="11"
                                   Margin="0,14,0,0"
                                   Foreground="{DynamicResource MutedForeground}" />
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </DockPanel>
</Window>
